{
  "openapi": "3.0.0",
  "info": {
    "title": "ApiScan E-Commerce API",
    "description": "A digital storefront API including product catalog searching and secure order placement.",
    "version": "1.0.0",
    "contact": {
      "name": "ApiScan Testing Team"
    }
  },
  "servers": [
    {
      "url": "https://store.apiscan.com/api/v1",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:8000/api/v1",
      "description": "Local Testing Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Product": {
        "type": "object",
        "required": ["id", "name", "price", "inStock"],
        "properties": {
          "id": {
            "type": "integer",
            "example": 101
          },
          "name": {
            "type": "string",
            "example": "Wireless Noise-Canceling Headphones"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 199.99
          },
          "inStock": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "Order": {
        "type": "object",
        "required": ["productId", "quantity"],
        "properties": {
          "productId": {
            "type": "integer",
            "example": 101
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "example": 2
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 401
          },
          "message": {
            "type": "string",
            "example": "Unauthorized access. Missing or invalid token."
          }
        }
      }
    }
  },
  "paths": {
    "/products": {
      "get": {
        "summary": "List all products",
        "description": "Retrieve a list of available products in the store. Can be filtered by category.",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "description": "Filter products by category name",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Place a new order",
        "description": "Creates a new order for a specific product. Requires an active JWT token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Order"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order successfully placed"
          },
          "401": {
            "description": "Authentication Failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  }
}